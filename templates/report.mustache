<div class="local-suap-relatorio">
    {{#hasdata}}
        <div class="alert alert-info mb-4">
            <i class="fa fa-clock-o"></i> Última atualização: {{lastupdated}}
        </div>

        <div class="accordion" id="accordion-cursos">
            {{#cursos}}
                <div class="card mb-2">
                    <div class="card-header" id="heading-{{curso_id}}">
                        <h2 class="mb-0">
                            <button class="btn btn-link btn-block text-left collapsed d-flex justify-content-between align-items-center" 
                                    type="button" 
                                    data-toggle="collapse" 
                                    data-target="#collapse-{{curso_id}}" 
                                    aria-expanded="false" 
                                    aria-controls="collapse-{{curso_id}}">
                                <strong>{{curso_nome}}</strong>
                                <i class="fa fa-chevron-down accordion-icon"></i>
                            </button>
                        </h2>
                    </div>
                    <div id="collapse-{{curso_id}}" 
                         class="collapse" 
                         aria-labelledby="heading-{{curso_id}}"
                         data-parent="#accordion-cursos">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-striped table-bordered table-sm mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th>Campus</th>
                                            <th>Total Inscritos</th>
                                            <th>Acessaram</th>
                                            <th>Nunca Acessaram</th>
                                            <th>% Acesso</th>
                                            <th>Fizeram Avaliação</th>
                                            <th>% Fizeram</th>
                                            <th>Aprovados</th>
                                            <th>Reprovados</th>
                                            <th>% Aprovados</th>
                                            <th>Nota Média</th>
                                            <th>Com Certificado</th>
                                            <th>Aptos sem Cert.</th>
                                            <th>Concluídos</th>
                                            <th>% Concluídos</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#campus_list}}
                                            <tr>
                                                <td><strong>{{campus_nome}}</strong></td>
                                                <td>{{total_enrolled}}</td>
                                                <td>{{accessed}}</td>
                                                <td>{{no_access}}</td>
                                                <td>{{pct_accessed}}%</td>
                                                <td>{{final_exam_takers}}</td>
                                                <td>{{pct_exam_takers}}%</td>
                                                <td class="table-success">{{passed}}</td>
                                                <td class="table-danger">{{failed}}</td>
                                                <td>{{pct_passed}}%</td>
                                                <td>{{avg_grade}}</td>
                                                <td>{{with_certificate}}</td>
                                                <td>{{without_certificate}}</td>
                                                <td class="table-info">{{completed}}</td>
                                                <td>{{pct_completed}}%</td>
                                            </tr>
                                        {{/campus_list}}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            {{/cursos}}
        </div>
    {{/hasdata}}

    {{^hasdata}}
        <div class="alert alert-warning">
            <i class="fa fa-exclamation-triangle"></i> {{nodatamessage}}
        </div>
    {{/hasdata}}
</div>

<style>
/* Ícone do accordion */
.local-suap-relatorio .accordion-icon {
    transition: transform 0.3s ease;
    font-size: 0.9rem;
    color: #666;
}

/* Quando o accordion está aberto (botão sem classe collapsed) */
.local-suap-relatorio .card-header button:not(.collapsed) .accordion-icon {
    transform: rotate(180deg);
}

/* Primeira coluna */
.local-suap-relatorio .table th:nth-child(1),
.local-suap-relatorio .table td:nth-child(1) {
    position: sticky;
    left: 0;
    z-index: 10;
    background-color: #fff;
    font-weight: 600;
    box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
}

.local-suap-relatorio .table th:nth-child(1) {
    background-color: #f8f9fa;
    z-index: 11;
}
</style>