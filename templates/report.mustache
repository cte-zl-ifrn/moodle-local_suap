<div class="local-suap-relatorio">

    {{^nodata}}

        <!-- Abas -->
        <ul class="nav nav-tabs mb-3" id="relatorioTabs" role="tablist">
            
            {{#has_minicursos}}
            <li class="nav-item">
                <a class="nav-link active"
                   id="minicursos-tab"
                   data-toggle="tab"
                   href="#minicursos"
                   role="tab">
                    Cursos Autoinstrucionais
                </a>
            </li>
            {{/has_minicursos}}

            {{#has_proitec}}
            <li class="nav-item">
                <a class="nav-link {{^has_minicursos}}active{{/has_minicursos}}"
                   id="proitec-tab"
                   data-toggle="tab"
                   href="#proitec"
                   role="tab">
                    PROITEC
                </a>
            </li>
            {{/has_proitec}}

        </ul>

        <div class="tab-content">

            <!-- ============================= -->
            <!-- ABA MINICURSOS -->
            <!-- ============================= -->
            {{#has_minicursos}}
            <div class="tab-pane fade show active" id="minicursos" role="tabpanel">

                <div class="alert alert-info mb-4">
                    <i class="fa fa-clock-o"></i>
                    Última atualização: {{minicursos.lastupdated}}
                </div>

                <div class="accordion" id="accordion-cursos">

                    {{#minicursos.cursos}}
                        <div class="card mb-2">

                            <div class="card-header d-flex justify-content-between" id="heading-{{curso_id}}">
                                <h2 class="mb-0 flex-grow-1">
                                    <button class="btn btn-link btn-block text-left collapsed d-flex justify-content-between align-items-center"
                                            type="button"
                                            data-toggle="collapse"
                                            data-target="#collapse-{{curso_id}}">
                                        <strong>{{curso_nome}}</strong>
                                        <i class="fa fa-chevron-down accordion-icon"></i>
                                    </button>
                                </h2>

                                <a class="btn btn-outline-success ml-2"
                                   href="{{export_url}}">
                                    <i class="fa fa-file-excel-o"></i> Excel
                                </a>
                            </div>

                            <div id="collapse-{{curso_id}}"
                                 class="collapse"
                                 data-parent="#accordion-cursos">

                                <div class="card-body p-0">
                                    <div class="table-responsive">

                                        <table class="table table-striped table-bordered table-sm mb-0">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th>Campus</th>
                                                    <th>Código do curso</th>
                                                    <th>Total Inscritos</th>
                                                    <th>Acessaram</th>
                                                    <th>Nunca Acessaram</th>
                                                    <th>% Acesso</th>
                                                    <th>Fizeram Avaliação Final</th>
                                                    <th>% Fizeram Avaliação Final</th>
                                                    <th>Aprovados</th>
                                                    <th>Reprovados</th>
                                                    <th>% Aprovados</th>
                                                    <th>Nota Média</th>
                                                    <th>Com Certificado</th>
                                                    <th>Aptos sem Cert.</th>
                                                    <th>Concluídos</th>
                                                    <th>% Concluídos</th>
                                                </tr>
                                            </thead>

                                            <tbody>
                                                {{#campus_list}}
                                                <tr>
                                                    <td>
                                                        <a href="{{curso_url}}" target="_blank">
                                                            <strong>{{campus_nome}}</strong>
                                                        </a>
                                                    </td>
                                                    <td>{{curso_codigo}}</td>
                                                    <td>{{total_enrolled}}</td>
                                                    <td>{{accessed}}</td>
                                                    <td>{{no_access}}</td>
                                                    <td>{{pct_accessed}}%</td>
                                                    <td>{{final_exam_takers}}</td>
                                                    <td>{{pct_exam_takers}}%</td>
                                                    <td class="table-success">{{passed}}</td>
                                                    <td class="table-danger">{{failed}}</td>
                                                    <td>{{pct_passed}}%</td>
                                                    <td>{{avg_grade}}</td>
                                                    <td>{{with_certificate}}</td>
                                                    <td>{{without_certificate}}</td>
                                                    <td class="table-info">{{completed}}</td>
                                                    <td>{{pct_completed}}%</td>
                                                </tr>
                                                {{/campus_list}}
                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            </div>
                        </div>
                    {{/minicursos.cursos}}

                </div>
            </div>
            {{/has_minicursos}}


            <!-- ============================= -->
            <!-- ABA PROITEC -->
            <!-- ============================= -->
            {{#has_proitec}}
            <div class="tab-pane fade {{^has_minicursos}}show active{{/has_minicursos}}"
                 id="proitec"
                 role="tabpanel">

                <div class="alert alert-info mb-4">
                    <i class="fa fa-clock-o"></i>
                    Última atualização: {{proitec.lastupdated}}
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-sm">
                        <thead class="thead-light">
                            <tr>
                                <th>Ano/Semestre</th>
                                <th>Campus</th>
                                <th>Disciplina</th>
                                <th>Total Inscritos</th>
                                <th>Aprovados</th>
                                <th>Concluídos</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#proitec.records}}
                            <tr>
                                <td>{{ano_semestre}}</td>
                                <td>{{campus}}</td>
                                <td>{{disciplina}}</td>
                                <td>{{total_enrolled}}</td>
                                <td>{{passed}}</td>
                                <td>{{completed}}</td>
                            </tr>
                            {{/proitec.records}}
                        </tbody>
                    </table>
                </div>

            </div>
            {{/has_proitec}}

        </div>

    {{/nodata}}

    {{#nodata}}
        <div class="alert alert-warning">
            <i class="fa fa-exclamation-triangle"></i>
            {{nodatamessage}}
        </div>
    {{/nodata}}

</div>